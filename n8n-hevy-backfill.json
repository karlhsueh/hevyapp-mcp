      "parameters": {
        "operation": "clear",
        "documentId": {
          "__rl": true,
          "value": "1SbBE6LbSUo1T9YXNHruYWXkeHiouxKTpMvWJGj2YPRs",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
