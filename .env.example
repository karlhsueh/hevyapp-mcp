HEVY_API_KEY=your-api-key-here          # from hevy.com/settings?developer (requires Hevy Pro)
MCP_AUTH_TOKEN=your-secret-token        # generate one: openssl rand -hex 32
MCP_TRANSPORT=sse                       # "sse" enables HTTP server mode; omit for local stdio mode
PORT=3847                               # port the HTTP server listens on
SERVER_BASE_URL=https://your-public-url # your public URL, used for OAuth endpoints
DATA_DIR=/data                          # where OAuth tokens are persisted (optional, defaults to /data)
